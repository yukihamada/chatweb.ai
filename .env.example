# chatweb.ai Environment Variables
# Copy to .env and fill in your values

# ── Required ──
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── Google OAuth (for Gmail/Calendar/Drive) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional: Additional LLM Providers ──
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Messaging ──
SYNAPSE_BOT_TOKEN=        # Telegram bot token
TELEGRAM_CHAT_ID=         # Admin Telegram chat ID
LINE_CHANNEL_ACCESS_TOKEN=
LINE_BOT_BASIC_ID=

# ── Payments ──
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_WEBHOOK_SECRET=

# ── Other ──
RESEND_API_KEY=           # Email sending
E2B_API_KEY=              # Code execution sandbox
ADMIN_TOKEN=              # Admin API access (required for admin endpoints)
APP_BASE_URL=https://chatweb.ai
DB_PATH=/data/hitl.db
