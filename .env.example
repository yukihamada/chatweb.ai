# Copy this file to .env and fill in your values

# Required
ANTHROPIC_API_KEY=sk-ant-api03-...

# Economy tier model (Groq)
GROQ_API_KEY=gsk_...

# Google OAuth (login + Gmail/Calendar/Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_BOT_BASIC_ID=@...

# Telegram Bot
TELEGRAM_TOKEN=
TELEGRAM_BOT_USERNAME=chatweb_aichat_bot
TELEGRAM_CHAT_ID=

# Search APIs
TAVILY_API_KEY=tvly-...

# Email
RESEND_API_KEY=re_...

# Admin
ADMIN_EMAILS=your@email.com
ADMIN_TOKEN=your-admin-token

# Database
DB_PATH=/data/synapse.db
